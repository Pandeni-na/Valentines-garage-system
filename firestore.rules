// firestore.rules
// Deploy these rules in your Firebase Console → Firestore → Rules tab.
//
// Security model:
//   - Anyone authenticated can read/write trucks and tasks
//     (in a real deployment you would restrict writes by role)
//   - Users can only read their own profile document

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;  // Only admins create users (done manually in Console)
    }

    // Any authenticated user can read and write trucks
    match /trucks/{truckId} {
      allow read, write: if request.auth != null;

      // Tasks live as a sub-collection under each truck
      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
